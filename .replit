modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "gce"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-mail:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 21285
externalPort = 3003

[[ports]]
localPort = 23821
externalPort = 3001

[[ports]]
localPort = 24226
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
OWNER_EMAIL = "axel@saerensadvertising.com"
AGENT_EMAIL_DOMAIN = "saerensadvertising.com"
ATLAS_DEPLOYMENT_MODE = "reserved-vm"

# Workspace Atlas graph scope. Public ClickUp object identifiers, never secrets.
GRAPH_WORKSPACE_ID = "9015913612"
GRAPH_ALLOWED_SPACE_IDS = "901511402568,901511402422"
GRAPH_ALLOWED_LIST_IDS = "901524400055,901524400063"
# Client Delivery is a bounded semantic projection: include every live list in
# this one Space while the HQ Space remains restricted to the explicit lists.
GRAPH_FULL_SPACE_IDS = "901511402422"
# Explicit Company task -> client Folder ownership. Never infer customer truth
# from labels: these public ClickUp ids are the reviewed composition contract.
GRAPH_CLIENT_FOLDER_COMPANY_MAP = "901516752267:86carekxv,901516752271:86carekxu,901516752272:86carekxw,901516751785:86carekxx,901516752275:86careky0,901516752284:86carekxz"
GRAPH_ALLOWED_DOC_IDS = "8cp7v4c-71935,8cp7v4c-73895"
GRAPH_TASK_LOOKBACK_DAYS = "90"
GRAPH_MAX_TASKS_PER_LIST = "25"
GRAPH_MAX_TASKS_TOTAL = "100"
GRAPH_MAX_DOCS = "2"
GRAPH_MAX_PAGES_PER_DOC = "150"
GRAPH_MAX_PAGES_TOTAL = "250"
GRAPH_MAX_PUSH_RECORDS = "100"

# Production uses the bounded overview. Search and neighbor expansion still reach
# the complete active snapshot without shipping the entire graph on first load.
GRAPH_OVERVIEW_UNLIMITED = "false"
